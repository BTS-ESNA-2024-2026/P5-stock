{
  "name": "p5-stock",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "build": "pnpm --filter frontend build",
    "build:prod": "pnpm --filter frontend build && pnpm --filter backend build",
    "preview": "pnpm --filter frontend preview",
    "lint": "pnpm --filter frontend lint",
    "start:prod": "pnpm --filter backend start:prod"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}

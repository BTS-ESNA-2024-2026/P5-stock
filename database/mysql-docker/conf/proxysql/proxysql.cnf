# ProxySQL Configuration for MySQL HA
# Issue #38: Connection pooling and read/write splitting

datadir="/var/lib/proxysql"

admin_variables=
{
    admin_credentials="admin:admin;radmin:radmin"
    mysql_ifaces="0.0.0.0:6032"
    web_enabled=true
    web_port=6080
}

mysql_variables=
{
    threads=4
    max_connections=2048
    default_query_delay=0
    default_query_timeout=36000000
    have_compress=true
    poll_timeout=2000
    interfaces="0.0.0.0:6033"
    default_schema="P5DB"
    stacksize=1048576
    server_version="8.0.32"
    connect_timeout_server=3000
    monitor_username="monitor"
    monitor_password="monitor"
    monitor_history=600000
    monitor_connect_interval=60000
    monitor_ping_interval=10000
    monitor_read_only_interval=1500
    monitor_read_only_timeout=500
    ping_interval_server_msec=120000
    ping_timeout_server=500
    commands_stats=true
    sessions_sort=true
    connect_retries_on_failure=10
}

# MySQL servers configuration
mysql_servers =
(
    # Writer hostgroup (0) - Primary only
    {
        address = "mysql-primary"
        port = 3306
        hostgroup = 0
        weight = 1000
        max_connections = 500
        max_replication_lag = 0
        comment = "Primary - Read/Write"
    },
    # Reader hostgroup (1) - All servers for reads
    {
        address = "mysql-primary"
        port = 3306
        hostgroup = 1
        weight = 100
        max_connections = 500
        comment = "Primary - Fallback for reads"
    },
    {
        address = "mysql-replica-1"
        port = 3306
        hostgroup = 1
        weight = 1000
        max_connections = 500
        max_replication_lag = 10
        comment = "Replica 1 - Read-only"
    },
    {
        address = "mysql-replica-2"
        port = 3306
        hostgroup = 1
        weight = 1000
        max_connections = 500
        max_replication_lag = 10
        comment = "Replica 2 - Read-only"
    }
)

# User configuration
mysql_users =
(
    {
        username = "app_user"
        password = "app_password"
        default_hostgroup = 0
        max_connections = 1000
        default_schema = "P5DB"
        active = 1
    },
    {
        username = "root"
        password = "rootpassword"
        default_hostgroup = 0
        max_connections = 100
        active = 1
    }
)

# Query rules for read/write splitting
mysql_query_rules =
(
    # Send SELECT queries (reads) to reader hostgroup
    {
        rule_id = 1
        active = 1
        match_pattern = "^SELECT .* FOR UPDATE"
        destination_hostgroup = 0
        apply = 1
        comment = "SELECT FOR UPDATE goes to writer"
    },
    {
        rule_id = 2
        active = 1
        match_pattern = "^SELECT"
        destination_hostgroup = 1
        apply = 1
        comment = "SELECT goes to readers"
    },
    # All other queries (INSERT, UPDATE, DELETE) go to writer
    {
        rule_id = 100
        active = 1
        match_pattern = ".*"
        destination_hostgroup = 0
        apply = 1
        comment = "Default to writer"
    }
)

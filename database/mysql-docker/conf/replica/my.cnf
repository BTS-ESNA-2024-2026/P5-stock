[mysqld]
# Binary logging for cascading replication
log-bin = mysql-bin
binlog-format = ROW
binlog-row-image = FULL
expire-logs-days = 7

# GTID configuration
gtid-mode = ON
enforce-gtid-consistency = ON
log-slave-updates = ON

# Read-only settings (enforced at startup via command)
read-only = ON
super-read-only = ON

# Semi-synchronous replication (Replica)
plugin-load-add = semisync_replica=semisync_replica.so

# InnoDB settings
innodb-buffer-pool-size = 256M
innodb-log-file-size = 64M

# Performance settings
max-connections = 500

# Character set
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# Relay log settings
relay-log = relay-bin
relay-log-recovery = ON
relay-log-info-repository = TABLE
master-info-repository = TABLE

# Configuration de l'environnement
FLASK_ENV=development
FLASK_APP=main.py
FLASK_DEBUG=1

# Clés secrètes (CHANGER EN PRODUCTION)
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Chemins des clés RSA pour JWT (RS256)
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem

# Base de données (à activer quand la DB sera prête)
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/sglm
# DATABASE_HOST=localhost
# DATABASE_PORT=3306
# DATABASE_NAME=sglm
# DATABASE_USER=sglm_user
# DATABASE_PASSWORD=secure_password

# Redis (pour cache et rate limiting)
# REDIS_URL=redis://localhost:6379/0
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO

# Configuration MFA
MFA_ISSUER_NAME=SGLM

# Email (pour envoi de credentials, alertes, etc.)
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=noreply@sglm.mil
# MAIL_PASSWORD=your-mail-password

# Uploads
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=10485760  # 10MB

# API Configuration
API_VERSION=v1

# Security
SESSION_COOKIE_SECURE=False  # True en production avec HTTPS
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Strict

# Rate Limiting
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=100/hour

# Timezone
TIMEZONE=UTC

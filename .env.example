# P5-Stock Environment Configuration
# Copy this file to .env and update values

# ============================================
# Flask Application
# ============================================
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change_me_in_production

# ============================================
# Database (MySQL)
# ============================================
# For development (single instance)
DATABASE_URL=mysql+pymysql://app_user:app_password@localhost:3306/P5DB

# For production (via ProxySQL)
# DATABASE_URL=mysql+pymysql://app_user:app_password@proxysql:6033/P5DB

MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=P5DB
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password

# ============================================
# Redis Cache (Issue #35)
# ============================================
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300

# ============================================
# Security (Issue #28)
# ============================================
CSRF_ENABLED=true
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=10/second

# Session security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=change_me_in_production
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRES=600
JWT_REFRESH_TOKEN_EXPIRES=86400

# ============================================
# Backup Configuration (Issue #29)
# ============================================
BACKUP_ENABLED=true
S3_BUCKET=p5stock-backups
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=eu-west-1
ENCRYPTION_ENABLED=true

# ============================================
# Monitoring
# ============================================
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true

# ============================================
# Orchestrator (Issue #38)
# ============================================
ORC_TOPOLOGY_PASSWORD=orch_password
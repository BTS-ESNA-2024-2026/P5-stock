{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install": "python3 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt",
    "dev": "source .venv/bin/activate && python -m flask --app src run --debug --port 5000",
    "start:prod": "source .venv/bin/activate && gunicorn -w 4 -b 0.0.0.0:5000 'src:create_app()'",
    "build": "echo 'Backend ready for production'"
  }
}

# Environment variables for Docker production deployment
# Copy to .env and update values

# Required: Database
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_NAME=p5_stock
# Note: if postgres_data volume already exists, changing DB_PASSWORD here does not
# rotate the database password automatically. Keep the original password, change it
# inside PostgreSQL, or recreate the volume for non-production environments.

# Required: Backend
FLASK_SECRET_KEY=your_secret_key_here_change_this

# Frontend variables like VITE_API_URL should be defined in frontend/.env.production
